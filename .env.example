# Telegram
BOT_TOKEN=
ACCESS_PASSWORD=

# Storage
DATABASE_URL=sqlite+aiosqlite:////app/data/concierge.db

# LLM
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro
# "Thinking" do agente Gemini: -1 = automático (padrão, mais lento porém mais
# inteligente); 0 = desligado (acelera MUITO; só vale em flash/flash-lite);
# 128 = pensa pouco (rápido, válido também no pro). Reduz a latência das respostas.
GEMINI_THINKING_BUDGET=-1

# Override opcional só para entrada de imagens (foto enviada ao bot).
# Vazio = usa o /provider atual do usuário (default Anthropic).
# Útil pra usar Gemini em fotos (mais barato/free tier) mesmo quando o chat
# fica em Anthropic. Valores: anthropic | openai | gemini.
VISION_PROVIDER=

# Trânsito (Google Directions API) + consulta de estabelecimentos (tool
# buscar_local: telefone/endereço/horário OFICIAL do Google). A MESMA chave
# serve pros dois, mas habilite no projeto do Google Cloud, além da Directions
# API, a "Places API (New)" — senão buscar_local retorna 403.
# A previsão do tempo (Open-Meteo) usa HOME_COORDS, sem chave própria.
GOOGLE_MAPS_API_KEY=
HOME_COORDS=-23.5505,-46.6333
WORK_COORDS=-23.5614,-46.6559

# Rota habitual (opcional, mas recomendado):
# Abra https://maps.google.com → trace sua rota completa de casa→trabalho
# (clique em "adicionar parada" para incluir pontos intermediários que você
# usa de verdade) → clique em "Compartilhar" → "Copiar link" e cole abaixo.
# O bot vai extrair os waypoints e usar essa rota como "preferida", também
# comparando com a melhor alternativa do Google em tempo real.
# Se ficar vazio, o bot usa só a rota direta + 1 alternativa.
ROUTE_GOOGLE_MAPS_URL=

TRAFFIC_DIGEST_ENABLED=true
TRAFFIC_HOUR=7
TRAFFIC_MINUTE=20

# Medidas Provisórias — pauta de votação do Congresso
CONGRESS_DIGEST_ENABLED=true

# Monitor de MPs publicadas no Diário Oficial (Inlabs/DOU).
# Cadastro gratuito da credencial em https://inlabs.in.gov.br/acessar.php
# Reusa ANTHROPIC_API_KEY pra gerar a nota técnica. Entrega no Telegram
# (mensagem + DOCX). Digest diário no horário DOU_MP_HOUR:DOU_MP_MINUTE BRT
# pros usuários que derem /mp_dou_on. Independente do projeto Monitor-de-MP.
DOU_MP_ENABLED=true
DOU_MP_HOUR=18
DOU_MP_MINUTE=0
# Pesquisa de contexto via web search (enriquece o parágrafo de contexto).
# Desligue (false) se estiver lento ou indisponível — a nota ainda é gerada.
DOU_MP_WEB_RESEARCH=true
# Provider da nota técnica: "gemini" (padrão, MUITO mais barato — Flash +
# Google Search nativo) ou "anthropic" (Claude + web_search). Reusa a chave
# GEMINI_API_KEY / ANTHROPIC_API_KEY conforme o caso.
# gemini-2.5-pro dá análise jurídica bem mais densa (recomendado); use
# gemini-2.5-flash se quiser custo mínimo (a análise de impacto fica mais rasa).
DOU_MP_PROVIDER=gemini
DOU_MP_GEMINI_MODEL=gemini-2.5-pro
# Fallback automático se o principal estourar cota/429 (free tier do Pro
# tem limite baixo). Deixe vazio pra desligar o fallback.
DOU_MP_GEMINI_MODEL_FALLBACK=gemini-2.5-flash
INLABS_EMAIL=
INLABS_PASSWORD=

# Cotação de ativos da B3 (ações/FIIs/ETFs) via brapi.dev — cadastro gratuito
# em https://brapi.dev gera o token. Usado na revisão de carteira do agente
# proativo (última janela do dia): busca o preço de mercado, atualiza o
# currentPrice no Firestore e mostra investido vs mercado + P&L. Sem token,
# a revisão é simplesmente pulada (o resto do proativo segue normal).
BRAPI_TOKEN=

# Busca web com LEITURA de página — tool `buscar_web` + comando `/buscar`.
# Lê o corpo renderizado da página (não só snippets), necessário pra dados que
# só existem DENTRO da página e mudam com o tempo: horários de sessão de
# cinema, funcionamento, preços, cardápios.
#
# Backend PRIMÁRIO (searxng = padrão; ou firecrawl). Se ele falhar e
# WEBSEARCH_FALLBACK=true, o outro é tentado automaticamente. Backend sem
# credencial é pulado (não conta como falha).
WEBSEARCH_BACKEND=searxng
WEBSEARCH_FALLBACK=true
#
# SearXNG (self-hosted, custo zero): URL da instância. Habilite 'json' em
# search.formats no settings.yml. Setup em README → "Busca web".
SEARXNG_URL=http://192.168.1.50:8080
# Jina Reader lê cada link do SearXNG. OPCIONAL: sem key funciona no tier
# gratuito; com key (https://jina.ai/reader) o rate limit sobe.
JINA_API_KEY=
#
# Firecrawl (turnkey, gasta créditos) — usado como fallback por padrão. Crie a
# key (free tier) em https://www.firecrawl.dev → Dashboard → API Keys. Pode
# deixar vazio se só quiser o SearXNG.
FIRECRAWL_API_KEY=

# Agente proativo (opt-in por usuário via /proativo_on). Avisa sozinho sobre
# vencimentos chegando, briefing matinal, MP nova no DOU, nudges de hábito e
# revisão da carteira de investimentos na última janela do dia.
# Substitui o digest fixo de MP das 18h (MP agora é leve + nota sob demanda).
PROACTIVE_ENABLED=true
PROACTIVE_HOURS=7,13,19
PROACTIVE_BRIEFING_HOUR=7
PROACTIVE_LOOKAHEAD_HOURS=48    # vencimentos aparecem em toda janela dentro dessa antecedência
PROACTIVE_WORKOUT_IDLE_DAYS=4
PROACTIVE_FINANCE_IDLE_DAYS=7
PROACTIVE_SHOPPING_IDLE_DAYS=5
PROACTIVE_NUDGE_COOLDOWN_DAYS=3
# Redação dos avisos pelo LLM (voz amigável). false = texto determinístico
# (custo zero, sem alucinação). true usa o provider do usuário sem tools.
PROACTIVE_USE_LLM=false

# Scheduler
SCHEDULER_TICK_SECONDS=60
TIMEZONE=America/Sao_Paulo

# Voz (STT via Gemini multimodal — reutiliza GEMINI_API_KEY acima)
# Quando true, mensagens de áudio são transcritas e roteadas como comando (se
# começarem com /) ou como chat livre. Áudios acima de VOICE_MAX_SECONDS são
# rejeitados.
# VOICE_STT_MODEL: gemini-3.5-flash (default; geração nova),
#                  gemini-3.1-flash-lite, gemini-3.1-pro.
# Se TODA a cadeia Gemini falhar (503/500/404) e OPENAI_API_KEY estiver
# configurada, o bot cai automaticamente no Whisper como último recurso.
# (gemini-2.0-flash foi retirado pelo Google em 2026 — não use.)
VOICE_ENABLED=true
VOICE_MAX_SECONDS=120
VOICE_STT_MODEL=gemini-3.5-flash
# VOICE_STT_PROVIDER: "gemini" (default; faz conversão voz→/comando) ou
#                     "openai" (Whisper/gpt-4o-transcribe; transcrição literal,
#                     mais estável quando o Gemini 2.5 está sobrecarregado).
VOICE_STT_PROVIDER=gemini
VOICE_STT_OPENAI_MODEL=gpt-4o-mini-transcribe

# Agente de execução (estilo Claude Code) — owner-only.
# O bot escreve, EXECUTA e itera código dentro do container, confinado a
# /app/workspace (./workspace no host), e entrega os arquivos pelo Telegram.
# Acione com /agente <tarefa>, por voz ("barra agente ...") ou em linguagem
# natural no chat livre ("constrói um script que...").
#
# OWNER_TELEGRAM_ID (OBRIGATÓRIO pra ligar): seu ID numérico do Telegram
# (pegue com @userinfobot). Vazio = agente desabilitado; os demais usuários
# autorizados nem veem o recurso. Reusa a ANTHROPIC_API_KEY acima.
OWNER_TELEGRAM_ID=
# Token GitHub OPCIONAL (fine-grained PAT restrito SÓ aos repos que o agente
# pode tocar — nunca um token classic amplo). Com ele o agente clona repos
# privados, commita, faz push e abre PRs via git/gh. Sem ele, só clona públicos.
AGENT_GITHUB_TOKEN=
# Ajustes finos (todos têm default; mude em runtime via /agente_config sem
# reiniciar — o .env é só o valor inicial):
# AGENT_MODEL: claude-sonnet-4-6 (equilíbrio) | claude-opus-4-8 (tarefas
#              complexas, mais caro) | claude-haiku-4-5-20251001 (barato).
# AGENT_TIMEOUT_SECONDS: tempo máximo por tarefa (estourou → entrega parcial).
# AGENT_MAX_TURNS: máx. de ciclos pensar→agir (freia loop infinito).
# AGENT_MAX_COST_USD: teto de gasto de API POR TAREFA (não mensal).
# AGENT_SESSION_TTL_MINUTES: janela pós-tarefa em que sua próxima mensagem
#                            livre continua a MESMA sessão (/agente_fim encerra).
AGENT_MODEL=claude-sonnet-4-6
AGENT_TIMEOUT_SECONDS=900
AGENT_MAX_TURNS=40
AGENT_MAX_COST_USD=1.50
AGENT_SESSION_TTL_MINUTES=30
AGENT_WORKSPACE=/app/workspace
# Teto diário (US$) SOMADO das execuções AGENDADAS do agente (cron). 0 = sem
# teto. Protege a fatura quando uma tarefa recorrente roda sozinha (ex.: de
# hora em hora). Cada execução continua limitada por AGENT_MAX_COST_USD.
# Contador em memória — zera se o bot reiniciar.
AGENT_CRON_DAILY_BUDGET_USD=0

# Notificação ao reiniciar: bot manda '🟢 online' pros usuários autorizados
# logo após subir (deploy/restart/crash recovery). Default true. Desabilite
# se preferir restart silencioso.
RESTART_NOTIFICATION_ENABLED=true

# Logging
LOG_LEVEL=INFO
