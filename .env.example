# Telegram
BOT_TOKEN=
ACCESS_PASSWORD=

# Storage
DATABASE_URL=sqlite+aiosqlite:////app/data/concierge.db

# LLM
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro

# Trânsito (Google Directions API)
# A previsão do tempo (Open-Meteo) usa HOME_COORDS, sem chave própria.
GOOGLE_MAPS_API_KEY=
HOME_COORDS=-23.5505,-46.6333
WORK_COORDS=-23.5614,-46.6559

# Rota habitual (opcional, mas recomendado):
# Abra https://maps.google.com → trace sua rota completa de casa→trabalho
# (clique em "adicionar parada" para incluir pontos intermediários que você
# usa de verdade) → clique em "Compartilhar" → "Copiar link" e cole abaixo.
# O bot vai extrair os waypoints e usar essa rota como "preferida", também
# comparando com a melhor alternativa do Google em tempo real.
# Se ficar vazio, o bot usa só a rota direta + 1 alternativa.
ROUTE_GOOGLE_MAPS_URL=

TRAFFIC_DIGEST_ENABLED=true
TRAFFIC_HOUR=7
TRAFFIC_MINUTE=20

# Medidas Provisórias
CONGRESS_DIGEST_ENABLED=true

# Scheduler
SCHEDULER_TICK_SECONDS=60
TIMEZONE=America/Sao_Paulo

# Voz (STT via Gemini multimodal — reutiliza GEMINI_API_KEY acima)
# Quando true, mensagens de áudio são transcritas e roteadas como comando (se
# começarem com /) ou como chat livre. Áudios acima de VOICE_MAX_SECONDS são
# rejeitados.
VOICE_ENABLED=true
VOICE_MAX_SECONDS=120

# Logging
LOG_LEVEL=INFO
