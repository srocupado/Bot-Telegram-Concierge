# Telegram
BOT_TOKEN=
ACCESS_PASSWORD=

# Storage
DATABASE_URL=sqlite+aiosqlite:////app/data/concierge.db

# LLM
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro

# Trânsito (Google Maps Routes API)
GOOGLE_MAPS_API_KEY=
HOME_COORDS=-23.5505,-46.6333
WORK_COORDS=-23.5614,-46.6559

# Clima (Open-Meteo - não exige key)
WEATHER_LAT=-23.5505
WEATHER_LON=-46.6333

# Scheduler
SCHEDULER_TICK_SECONDS=60
TIMEZONE=America/Sao_Paulo

# Horários dos digests (formato HH:MM, locais à TIMEZONE)
TRAFFIC_DAILY_TIME=07:00
MP_WEEKLY_TIME=08:00

# Logging
LOG_LEVEL=INFO
