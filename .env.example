# Telegram
BOT_TOKEN=
ACCESS_PASSWORD=

# Storage
DATABASE_URL=sqlite+aiosqlite:////app/data/concierge.db

# LLM
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro

# Trânsito (Google Directions API) — replicado do Telegram-Travels
# A previsão do tempo (Open-Meteo) usa HOME_COORDS, sem chave própria.
GOOGLE_MAPS_API_KEY=
HOME_COORDS=-23.5505,-46.6333
WORK_COORDS=-23.5614,-46.6559
# Opcional: URL do Google Maps com waypoints da sua rota habitual.
# Quando preenchido, o bot usa esses waypoints como rota "preferida".
ROUTE_GOOGLE_MAPS_URL=
TRAFFIC_DIGEST_ENABLED=true
TRAFFIC_HOUR=7
TRAFFIC_MINUTE=20

# Medidas Provisórias
CONGRESS_DIGEST_ENABLED=true

# Scheduler
SCHEDULER_TICK_SECONDS=60
TIMEZONE=America/Sao_Paulo

# Logging
LOG_LEVEL=INFO
